# ──────────────────────────────────────────────────────────────
#  J.A.R.V.I.S. — Configuration
#  Copy this file to `.env` and fill in your own values:
#      cp .env.example .env
#  Only the two Telegram settings are REQUIRED. Everything else is
#  optional and degrades gracefully when left blank.
# ──────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────

# Telegram bot token — create a bot with @BotFather on Telegram,
# then paste the token it gives you here.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Your Telegram numeric user ID — the ONLY person the bot will talk to.
# Get it by messaging @userinfobot on Telegram.
# For a shared household, comma-separate multiple IDs: 111111,222222
ALLOWED_USER_ID=your-telegram-user-id-here

# ── SERVER ────────────────────────────────────────────────────

# Port the web dashboard + API listen on (default 3000).
PORT=3000

# SQLite database file (relative to project root).
DB_PATH=./data/jarvis.db

# ── LOCAL AI (optional — Ollama) ──────────────────────────────
# Install Ollama (https://ollama.com) and `ollama pull` these models
# for natural-language parsing, semantic memory and RAG. If Ollama is
# not running, the bot falls back to regex parsing + keyword search.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── CALENDAR (optional) ───────────────────────────────────────

# Auto-import .ics files dropped into this folder.
# Defaults to your OS Downloads folder if left blank.
# ICS_WATCH_DIR=

# Microsoft Graph (Office 365 / Outlook calendar sync). Leave blank to disable.
MS_CLIENT_ID=
MS_TENANT_ID=
MS_CLIENT_SECRET=

# ── ANYLIST (optional — shared shopping/todo lists) ───────────
# Your AnyList account credentials. Leave blank to disable.
ANYLIST_EMAIL=
ANYLIST_PASSWORD=

# ── LOCALE & CURRENCY ─────────────────────────────────────────
# IANA timezone name — used for reminders, calendar formatting and
# the AI's sense of "today". e.g. Europe/Istanbul, America/New_York.
TIMEZONE=Europe/Istanbul

# Currency shown throughout the budget UI (ISO 4217 code).
#   Turkey: TRY  ·  Eurozone: EUR  ·  US: USD  ·  UK: GBP
CURRENCY=TRY

# Number/amount formatting locale (BCP-47 tag).
#   Turkey: tr-TR  ·  Germany: de-DE  ·  US: en-US
LOCALE=tr-TR

# ── WEB DASHBOARD ─────────────────────────────────────────────
# PIN that protects the web dashboard on your WiFi network.
# Leave blank to disable PIN protection (anyone on the network can view).
WEB_PIN=

# Internal Next.js dev port (only used in `npm run dev`).
NEXT_PORT=3001

# ── SMART-HOME CONNECTORS (optional) ──────────────────────────
# Each connector reads its own key(s). `npm run configure` fills these in for
# you; you can also set them by hand. Leave blank to disable a connector.

# Demo/virtual devices for testing the smart-home flow with no hardware.
# Set to 1, restart, then use /cihazlar in the bot. Leave blank in real use.
DEMO_DEVICES=

# Govee smart lights — Govee Home app → profile → About Us → Apply for API Key
GOVEE_API_KEY=

# Home Assistant — control every light/switch/climate/vacuum entity (local, no
# cloud). Best home for cloud/hard-to-reach devices: robot vacuums (Mova/Dreame),
# Alexa media players, Tapo camera privacy — add them in HA, control via JARVIS.
# Token: Home Assistant → profile → Long-Lived Access Tokens → Create Token
HASS_URL=
HASS_TOKEN=

# tado° smart thermostat — no key to paste: connect via the Cihazlar page
# ("tado°" → Bağla) or `npm run configure`. The device-flow refresh token is
# stored here automatically and rotates itself. Leave blank; don't edit by hand.
TADO_REFRESH_TOKEN=
